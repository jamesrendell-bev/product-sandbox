# Copy to .env.local for local LIVE mode. Leave unset for stub mode (demo default).
# Vite only exposes VITE_-prefixed vars to the browser.
#
# PRODUCTION: must route via a thin server proxy; never ship the key to the
# browser — a build-time env var is baked into the public bundle and is readable.
VITE_BEV_API_BASE_URL=https://api.birdseyeview.ai
VITE_BEV_API_KEY=
