# Copy to .env and fill in. .env is gitignored.

# Anthropic key — powers organiser due-diligence and location-intel web search.
ANTHROPIC_API_KEY=sk-ant-...
RESEARCH_MODEL=claude-sonnet-4-6

# BEV CERA hazard API — leave VITE_BEV_API_KEY blank to run the risk triage on
# deterministic regional stubs. Set it to go live.
VITE_BEV_API_KEY=
VITE_BEV_API_BASE_URL=https://api.birdseyeview.ai
