# Copy to .env (Netlify CLI picks up automatically with `netlify dev`).
# Never commit the real key.
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the Claude model used for classification.
# Defaults to claude-haiku-4-5 (fast + cheap; right pick for constrained
# enum classification). Override to claude-sonnet-4-6 only if you want to
# A/B test classification quality.
CLAUDE_MODEL=claude-haiku-4-5
